<!-- Micro-interaction scripts -->
<script>
    document.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('mousedown', () => btn.classList.add('scale-95'));
        btn.addEventListener('mouseup', () => btn.classList.remove('scale-95'));
        btn.addEventListener('mouseleave', () => btn.classList.remove('scale-95'));
    });

    // Search bar focus effect
    const searchInput = document.querySelector('input[type="text"]');
    const searchContainer = searchInput.parentElement;
    searchInput.addEventListener('focus', () => {
        searchContainer.classList.add('ring-2', 'ring-primary/50');
    });
    searchInput.addEventListener('blur', () => {
        searchContainer.classList.remove('ring-2', 'ring-primary/50');
    });

    function toggleStatus(btn, currentStatus) {
        const card = btn.closest('.glass-panel');
        const badge = card.querySelector('span.rounded-full');
        const icon = btn.querySelector('.material-symbols-outlined');
        const isActive = currentStatus === 'Active' || btn.textContent.trim().startsWith('Disable');

        if (isActive) {
            badge.textContent = 'Inactive';
            badge.className = 'flex-shrink-0 px-sm py-xs rounded-full text-[10px] font-bold uppercase tracking-widest bg-on-surface-variant/10 text-on-surface-variant border border-on-surface-variant/20';
            icon.setAttribute('data-icon', 'check_circle');
            btn.childNodes[btn.childNodes.length - 1].textContent = ' Enable';
        } else {
            badge.textContent = 'Active';
            badge.className = 'flex-shrink-0 px-sm py-xs rounded-full text-[10px] font-bold uppercase tracking-widest bg-tertiary/10 text-tertiary border border-tertiary/20';
            icon.setAttribute('data-icon', 'block');
            btn.childNodes[btn.childNodes.length - 1].textContent = ' Disable';
        }
    }
</script>