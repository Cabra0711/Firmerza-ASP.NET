<!-- Right Side: Login/Register Form -->
<section class="flex-1 flex items-center justify-center">
    <div class="glass-panel w-full max-w-md p-xl rounded-[2rem] shadow-2xl relative overflow-hidden">
        <!-- Toggle Container -->
        <div class="relative bg-surface-container-low rounded-full p-1 mb-xl flex h-12">
            <div class="absolute h-10 bg-primary/20 border border-primary/30 rounded-full tab-transition w-1/2 left-1 top-1"
                 id="tab-indicator"></div>
            <button class="relative flex-1 z-10 font-label-md text-label-md flex items-center justify-center gap-xs text-on-surface transition-colors"
                    onclick="toggleTab('login')">
                <span class="material-symbols-outlined text-sm" data-icon="admin_panel_settings"></span>
                Admin Access
            </button>
            <button class="relative flex-1 z-10 font-label-md text-label-md flex items-center justify-center gap-xs text-on-surface-variant hover:text-on-surface transition-colors"
                    onclick="toggleTab('register')">
                <span class="material-symbols-outlined text-sm" data-icon="person_add"></span>
                Customer Sign-up
            </button>
        </div>

        <!-- Form Heading -->
        <div class="mb-lg">
            <h2 class="font-headline-md text-headline-md text-on-surface" id="form-title">Welcome back</h2>
            <p class="font-body-md text-body-md text-on-surface-variant" id="form-subtitle">Enter your credentials to access the workspace.</p>
        </div>

        <form class="space-y-lg" onsubmit="event.preventDefault();">
            <!-- Input Fields -->
            <div class="space-y-md">
                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="email" placeholder="Email" type="email"/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="email">Workspace Email</label>
                </div>
                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="password" placeholder="Password" type="password"/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="password">Access Key</label>
                    <button class="absolute right-md top-4 text-on-surface-variant hover:text-primary" type="button">
                        <span class="material-symbols-outlined text-xl" data-icon="visibility"></span>
                    </button>
                </div>
            </div>

            <div class="flex items-center justify-between text-xs">
                <label class="flex items-center gap-xs cursor-pointer group">
                    <div class="w-4 h-4 rounded border border-outline group-hover:border-primary transition-colors flex items-center justify-center bg-surface-container">
                        <div class="w-2 h-2 bg-primary rounded-sm opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                    </div>
                    <span class="text-on-surface-variant group-hover:text-on-surface transition-colors">Remember device</span>
                </label>
                <a class="text-primary hover:underline transition-all" href="#">Forgot Key?</a>
            </div>

            <!-- Primary Action -->
            <button class="w-full bg-primary text-on-primary h-14 rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm glow-indigo hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
                Enter Workspace
                <span class="material-symbols-outlined" data-icon="arrow_forward"></span>
            </button>
        </form>

        <footer class="mt-xl text-center space-y-md">
            <p class="text-xs text-on-surface-variant">
                By entering, you agree to our
                <a class="text-on-surface underline" href="#">Terms of Service</a> and
                <a class="text-on-surface underline" href="#">Privacy Protocol</a>.
            </p>
        </footer>
    </div>
</section>


<div class="fixed bottom-0 w-full py-xl bg-surface-container-lowest/10 backdrop-blur-sm border-t border-outline-variant flex flex-col items-center justify-center space-y-md z-20">
    <div class="flex space-x-lg">
        <a class="font-body-md text-body-md text-on-surface-variant hover:text-secondary transition-colors" href="#">Privacy Policy</a>
        <a class="font-body-md text-body-md text-on-surface-variant hover:text-secondary transition-colors" href="#">Terms of Service</a>
        <a class="font-body-md text-body-md text-on-surface-variant hover:text-secondary transition-colors" href="#">Help Center</a>
        <a class="font-body-md text-body-md text-on-surface-variant hover:text-secondary transition-colors" href="#">API Docs</a>
    </div>
    <p class="font-body-md text-body-md text-on-surface-variant opacity-50">© 2024 StockStream Inventory Systems</p>
</div>

<script>
    function toggleTab(mode) {
        const indicator = document.getElementById('tab-indicator');
        const title = document.getElementById('form-title');
        const subtitle = document.getElementById('form-subtitle');
        const buttons = document.querySelectorAll('button[onclick^="toggleTab"]');

        if (mode === 'login') {
            indicator.style.left = '4px';
            title.innerText = 'Welcome back';
            subtitle.innerText = 'Enter your credentials to access the workspace.';
            buttons[0].classList.add('text-on-surface');
            buttons[0].classList.remove('text-on-surface-variant');
            buttons[1].classList.remove('text-on-surface');
            buttons[1].classList.add('text-on-surface-variant');
        } else {
            indicator.style.left = 'calc(50% - 4px)';
            title.innerText = 'Join the network';
            subtitle.innerText = 'Create your secure account to start scaling.';
            buttons[1].classList.add('text-on-surface');
            buttons[1].classList.remove('text-on-surface-variant');
            buttons[0].classList.remove('text-on-surface');
            buttons[0].classList.add('text-on-surface-variant');
        }
    }

    document.addEventListener('mousemove', (e) => {
        const blobs = document.querySelectorAll('.animated-blob');
        const x = (e.clientX / window.innerWidth) - 0.5;
        const y = (e.clientY / window.innerHeight) - 0.5;

        blobs.forEach((blob, index) => {
            const speed = (index + 1) * 20;
            blob.style.transform = `translate(${x * speed}px, ${y * speed}px)`;
        });
    });
</script>