<section class="flex-1 flex items-center justify-center">
    <div class="glass-panel w-full max-w-md p-xl rounded-[2rem] shadow-2xl relative overflow-hidden">

        <!-- Tab Toggle -->
        <div class="relative bg-surface-container-low rounded-full p-1 mb-xl flex h-12">
            <div class="absolute h-10 bg-primary/20 border border-primary/30 rounded-full tab-transition w-1/2 left-1 top-1"
                 id="tab-indicator"></div>
            <button class="relative flex-1 z-10 font-label-md text-label-md flex items-center justify-center gap-xs text-on-surface transition-colors"
                    onclick="switchTab('login')" id="btn-login">
                <span class="material-symbols-outlined text-sm" data-icon="admin_panel_settings"></span>
                Log In
            </button>
            <button class="relative flex-1 z-10 font-label-md text-label-md flex items-center justify-center gap-xs text-on-surface-variant hover:text-on-surface transition-colors"
                    onclick="switchTab('register')" id="btn-register">
                <span class="material-symbols-outlined text-sm" data-icon="person_add"></span>
                Sign up
            </button>
        </div>

        <!-- LOGIN PANEL -->
        <div id="panel-login" class="form-panel">
            <div class="mb-lg">
                <h2 class="font-headline-md text-headline-md text-on-surface">Welcome back</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Enter your credentials to access the workspace.</p>
            </div>

            <form method="post" asp-action="Login" class="space-y-lg">
                <div class="space-y-md">
                    <div class="relative group">
                        <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                               id="username" name="username" placeholder="Username" type="text" required/>
                        <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                               for="username">username</label>
                    </div>
                    <div class="relative group">
                        <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                               id="login-password" name="password" placeholder="Password" type="password" required/>
                        <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                               for="login-password">password</label>
                        <button class="absolute right-md top-4 text-on-surface-variant hover:text-primary" type="button"
                                onclick="togglePass('login-password', this)">
                            <span class="material-symbols-outlined text-xl" data-icon="visibility"></span>
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-end text-xs">
                    <a class="text-primary hover:underline transition-all" href="#">Forgot password?</a>
                </div>

                <button type="submit"
                        class="w-full bg-primary text-on-primary h-14 rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm glow-indigo hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
                    Enter Workspace
                    <span class="material-symbols-outlined" data-icon="arrow_forward"></span>
                </button>
            </form>
        </div>

        <!-- REGISTER PANEL -->
        <div id="panel-register" class="form-panel hidden">
            <div class="mb-lg">
                <h2 class="font-headline-md text-headline-md text-on-surface">Join the network</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Create your secure account to start scaling.</p>
            </div>
            
            @if (ViewBag.ErrorValidation != null)
            {
                <div class="bg-error/10 border border-error/20 text-error p-md rounded-xl text-xs space-y-1">
                    <p class="font-bold">Por favor corrige los siguientes campos:</p>
                    <p>@Html.Raw(ViewBag.ErrorValidation)</p>
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="bg-error/10 border border-error/20 text-error p-md rounded-xl text-xs font-medium">
                    @ViewBag.Error
                </div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="bg-success/10 border border-success/20 text-success p-md rounded-xl text-xs font-medium">
                    @ViewBag.Success
                </div>
            }
            <form method="post" asp-action="Register" class="space-y-md">
                
                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="reg-username" name="Username" placeholder="Username" type="text" required/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="reg-username">Username</label>
                </div>

                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="document" name="Document" placeholder="Document" type="text" required/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="document">Document number</label>
                </div>

                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="phone" name="Email" placeholder="Email" type="email" required/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="phone">Email</label>
                </div>

                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="reg-password" name="Password" placeholder="Password" type="password" required/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="reg-password">Password</label>
                    <button class="absolute right-md top-4 text-on-surface-variant hover:text-primary" type="button"
                            onclick="togglePass('reg-password', this)">
                        <span class="material-symbols-outlined text-xl" data-icon="visibility"></span>
                    </button>
                </div>

                <div class="relative group">
                    <input class="peer w-full bg-surface-container/50 border border-outline-variant rounded-xl px-md py-4 text-on-surface placeholder-transparent focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none"
                           id="confirm-password" name="ConfirmPassword" placeholder="Confirm" type="password" required/>
                    <label class="absolute left-md top-1 text-xs text-primary font-label-md transition-all peer-placeholder-shown:top-4 peer-placeholder-shown:text-body-md peer-placeholder-shown:text-on-surface-variant peer-focus:top-1 peer-focus:text-xs peer-focus:text-primary pointer-events-none"
                           for="confirm-password">Confirm password</label>
                </div>

                <button type="submit"
                        class="w-full bg-primary text-on-primary h-14 rounded-xl font-label-md text-label-md flex items-center justify-center gap-sm glow-indigo hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
                    Create Account
                    <span class="material-symbols-outlined" data-icon="arrow_forward"></span>
                </button>
            </form>
        </div>

        <footer class="mt-xl text-center space-y-md">
            <p class="text-xs text-on-surface-variant">
                By entering, you agree to our
                <a class="text-on-surface underline" href="#">Terms of Service</a> and
                <a class="text-on-surface underline" href="#">Privacy Protocol</a>.
            </p>
        </footer>
    </div>
</section>

<script>
    function switchTab(tab) {
        const indicator = document.getElementById('tab-indicator');
        const btnLogin = document.getElementById('btn-login');
        const btnRegister = document.getElementById('btn-register');
        const panelLogin = document.getElementById('panel-login');
        const panelRegister = document.getElementById('panel-register');

        if (tab === 'login') {
            indicator.style.left = '4px';
            btnLogin.classList.remove('text-on-surface-variant');
            btnLogin.classList.add('text-on-surface');
            btnRegister.classList.remove('text-on-surface');
            btnRegister.classList.add('text-on-surface-variant');
            panelLogin.classList.remove('hidden');
            panelRegister.classList.add('hidden');
        } else {
            indicator.style.left = 'calc(50% - 4px)';
            btnRegister.classList.remove('text-on-surface-variant');
            btnRegister.classList.add('text-on-surface');
            btnLogin.classList.remove('text-on-surface');
            btnLogin.classList.add('text-on-surface-variant');
            panelRegister.classList.remove('hidden');
            panelLogin.classList.add('hidden');
        }
    }

    function togglePass(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('span');
        if (input.type === 'password') {
            input.type = 'text';
            icon.setAttribute('data-icon', 'visibility_off');
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.setAttribute('data-icon', 'visibility');
            icon.textContent = 'visibility';
        }
    }
</script>
