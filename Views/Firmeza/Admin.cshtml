@model Firmeza.Response.ServiceResponse<IEnumerable<Product>>

@using Firmeza.Enums
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor



@{
    ViewData["Title"] = "Dashboard Admin";
    

    var nombreAdmin = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Admin";
}

<aside class="h-screen w-64 fixed left-0 top-0 bg-surface-container-low/60 backdrop-blur-md shadow-sm flex flex-col py-md px-sm z-50">
    <div class="mb-xl px-md">
        <h1 class="font-headline-md text-headline-md font-bold text-primary tracking-tight">Firmeza</h1>
        <p class="text-on-surface-variant font-label-md text-label-md opacity-70">Admin Console</p>
    </div>
    
    <nav class="flex-1 space-y-sm">
        <a class="flex items-center gap-md p-md rounded-lg text-primary font-bold bg-primary-container/10 border-r-4 border-primary transition-all duration-200 scale-98" asp-controller="Firmeza" asp-action="Admin">
            <span class="material-symbols-outlined" data-icon="dashboard"></span>
            <span class="font-body-md text-body-md">Products</span>
        </a>
        <a  asp-action="Customer" asp-controller="Firmeza" class="flex items-center gap-md p-md rounded-lg text-on-surface-variant hover:bg-primary-container/20 transition-all duration-200" >
            <span class="material-symbols-outlined" data-icon="inventory_2"></span>
            <span class="font-body-md text-body-md">Customers</span>
        </a>
        <a class="flex items-center gap-md p-md rounded-lg text-on-surface-variant hover:bg-primary-container/20 transition-all duration-200" asp-action="Sells" asp-controller="Firmeza">
            <span class="material-symbols-outlined" data-icon="monitoring"></span>
            <span class="font-body-md text-body-md">Sells</span>
        </a>
        <a class="flex items-center gap-md p-md rounded-lg text-on-surface-variant hover:bg-primary-container/20 transition-all duration-200" href="#">
            <span class="material-symbols-outlined" data-icon="settings"></span>
            <span class="font-body-md text-body-md">Settings</span>
        </a>
    </nav>
    
    <div class="mt-auto px-md pb-md flex items-center gap-md border-t border-outline-variant/20 pt-md">
        <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center relative">
            <span class="material-symbols-outlined text-on-primary-container text-2xl" style="font-variation-settings: 'FILL' 1;" data-icon="account_circle"></span>
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 absolute bottom-0 right-0 border-2 border-slate-900 animate-pulse"></div>
        </div>
        <div class="flex flex-col overflow-hidden">
            <span class="font-label-md text-label-md text-on-surface font-bold truncate">@nombreAdmin</span>
            <span class="text-[10px] text-on-surface-variant uppercase tracking-wider font-semibold">Rol: Administrador</span>
        </div>
        <a asp-controller="Firmeza" asp-action="Logout" 
           class="p-2 text-on-surface-variant hover:text-error hover:bg-error/10 rounded-xl transition-all duration-200 flex items-center justify-center group" 
           title="Cerrar sesión">
            <span class="material-symbols-outlined text-xl group-hover:scale-105 transition-transform" data-icon="logout"></span>
        </a>
    </div>
    
</aside>

<main class="ml-64 flex-1 p-xl relative min-h-screen bg-slate-900 text-white">
    <header class="flex justify-between items-center mb-xl border-b border-slate-800 pb-5">
        <div>
            <h2 class="font-headline-lg text-headline-lg text-on-surface font-bold">¡Bienvenido de nuevo, <span class="text-emerald-400">@nombreAdmin</span>! 👋</h2>
            <p class="text-on-surface-variant font-body-md text-body-md">Real-time stock monitoring & logistics</p>
        </div>
        <div class="flex items-center gap-md">
            <div class="glass-card flex items-center px-md py-sm rounded-full bg-slate-800/50 border border-slate-700">
                <span class="material-symbols-outlined text-primary mr-sm" data-icon="search"></span>
                <input class="bg-transparent border-none focus:ring-0 text-sm w-48 text-on-surface placeholder-slate-500" placeholder="Global system search..." type="text"/>
            </div>
            <button class="bg-secondary-container text-on-secondary-container px-lg py-sm rounded-full font-label-md text-label-md hover:scale-105 transition-transform bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                System Health: 98%
            </button>
        </div>
    </header>

    <section class="grid grid-cols-12 gap-lg mb-2xl">
        <div class="col-span-12 md:col-span-4 glass-card p-xl rounded-xl relative overflow-hidden group bg-slate-800/40 border border-slate-700/50">
            <div class="relative z-10">
                <div class="flex justify-between items-start mb-md">
                    <span class="material-symbols-outlined text-primary text-3xl" data-icon="inventory" style="font-variation-settings: 'FILL' 1;"></span>
                </div>
                <h3 class="text-on-surface-variant font-label-md text-label-md uppercase tracking-wider text-slate-400 text-xs">Total Products</h3>
                <p class="font-display-lg text-display-lg text-primary mt-xs font-bold text-3xl">@Model.Data.Count()</p>
            </div>
            <div class="absolute bottom-0 right-0 opacity-10 group-hover:scale-110 transition-transform duration-500">
                <span class="material-symbols-outlined text-9xl translate-x-12 translate-y-8" data-icon="layers"></span>
            </div>
        </div>
        @if (Model.Data.Count(p => p.Status == ProductStatus.LowStock) > 0)
        {
            <div class="col-span-12 md:col-span-4 glass-card p-xl rounded-xl relative overflow-hidden group border-error/20 bg-slate-800/40 border">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-md">
                        <span class="material-symbols-outlined text-error text-3xl" data-icon="warning" style="font-variation-settings: 'FILL' 1;"></span>
                        <span class="text-error font-label-md text-label-md font-bold text-xs">Action Required</span>
                    </div>
                    <h3 class="text-on-surface-variant font-label-md text-label-md uppercase tracking-wider text-slate-400 text-xs">Low Stock Alerts</h3>
                    <p class="font-display-lg text-display-lg text-error mt-xs font-bold text-3xl">@Model.Data.Count(p => p.Status == ProductStatus.LowStock)</p>
                </div>
                <div class="absolute bottom-0 right-0 opacity-10 group-hover:scale-110 transition-transform duration-500">
                    <span class="material-symbols-outlined text-9xl translate-x-12 translate-y-8" data-icon="emergency"></span>
                </div>
            </div>
        }
        <div class="col-span-12 md:col-span-4 glass-card p-xl rounded-xl relative overflow-hidden group bg-slate-800/40 border border-slate-700/50">
            <div class="relative z-10">
                <div class="flex justify-between items-start mb-md">
                    <span class="material-symbols-outlined text-tertiary text-3xl" data-icon="payments" style="font-variation-settings: 'FILL' 1;"></span>
                    <span class="text-tertiary font-label-md text-label-md">Trending Up</span>
                </div>
                <h3 class="text-on-surface-variant font-label-md text-label-md uppercase tracking-wider text-slate-400 text-xs">Weekly Revenue</h3>
                <p class="font-display-lg text-display-lg text-tertiary mt-xs font-bold text-3xl">$94.2k</p>
            </div>
            <div class="absolute bottom-0 right-0 opacity-10 group-hover:scale-110 transition-transform duration-500">
                <span class="material-symbols-outlined text-9xl translate-x-12 translate-y-8" data-icon="trending_up"></span>
            </div>
        </div>
    </section>

    <section class="glass-card rounded-xl overflow-hidden mb-2xl bg-slate-800/20 border border-slate-700/50">
        <div class="p-lg border-b border-outline-variant/30 flex flex-col md:flex-row justify-between items-center gap-md">
            <h3 class="font-headline-md text-headline-md text-on-surface font-bold">Product Inventory</h3>
            <div class="flex items-center gap-sm">
                <div class="bg-slate-800 flex items-center px-md py-2 rounded-lg border border-slate-700">
                    <span class="material-symbols-outlined text-on-surface-variant mr-xs text-sm" data-icon="filter_list"></span>
                    <select class="bg-transparent border-none focus:ring-0 text-sm text-on-surface-variant cursor-pointer text-slate-300">
                        <option class="bg-slate-800">All Categories</option>
                        <option class="bg-slate-800">Electronics</option>
                        <option class="bg-slate-800">Hardware</option>
                        <option class="bg-slate-800">Logistics</option>
                        <option class="bg-slate-800">Home</option>
                        <option class="bg-slate-800">Clothing</option>
                    </select>
                </div>
                <div class="bg-slate-800 flex items-center px-md py-2 rounded-lg border border-slate-700">
                    <span class="material-symbols-outlined text-on-surface-variant mr-xs text-sm" data-icon="sort"></span>
                    <select class="bg-transparent border-none focus:ring-0 text-sm text-on-surface-variant cursor-pointer text-slate-300">
                        <option class="bg-slate-800">Price: High to Low</option>
                        <option class="bg-slate-800">Quantity: Low to High</option>
                        <option class="bg-slate-800">Alphabetical</option>
                    </select>
                </div>
                <button class="p-2 bg-slate-800 border border-slate-700 rounded-lg hover:bg-primary-container/20 transition-colors">
                    <span class="material-symbols-outlined text-primary" data-icon="cloud_download"></span>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-[auto_1fr_auto_auto_auto_auto] items-center gap-md px-lg py-sm border-b border-slate-700 text-slate-400 font-label-md text-label-md uppercase tracking-wider text-xs">
            <div class="w-16"></div>
            <div>Product</div>
            <div class="w-28 text-center">Status</div>
            <div class="w-24 text-right">Price</div>
            <div class="w-28 text-right">Quantity</div>
            <div class="w-16"></div>
        </div>

        <div class="divide-y divide-slate-800">
           @foreach (var product in Model.Data)
           {
                <div class="grid grid-cols-[auto_1fr_auto_auto_auto_auto] items-center gap-md px-lg py-md hover:bg-white/5 transition-colors group">
                    <img class="w-16 h-16 rounded-lg object-cover flex-shrink-0 bg-slate-700" src="@product.ImageUrl" alt="product-image"/>
                <div>
                    <p class="font-bold text-on-surface text-body-md text-white">@product.Name</p>
                    <p class="text-slate-400 font-label-md text-label-md text-xs">SKU: @product.Sku</p>
                </div>
                <div class="w-28 flex justify-center">
                    @if (product.Quantity <= 30)
                    {
                        <span class="text-[10px] px-sm py-xs rounded uppercase font-bold border bg-amber-500/10 text-amber-400 border-amber-500/20">
                            LowStock
                        </span>
                    }else if (product.Quantity > 30)
                    {
                        <span class="text-[10px] px-sm py-xs rounded uppercase font-bold border bg-emerald-500/10 text-emerald-400 border-emerald-500/20">
                            InStock
                        </span>
                    }else if (product.Quantity == 0)
                    {
                        <span class="text-[10px] px-sm py-xs rounded uppercase font-bold border bg-slate-500/10 text-slate-400 border-slate-500/20">
                            OutOfStock
                        </span>
                    }else if (product.Status == ProductStatus.Unavailable)
                    {
                        <span class="text-[10px] px-sm py-xs rounded uppercase font-bold border bg-red-500/10 text-red-400 border-red-500/20">
                            Unavailable
                        </span>
                    }
                </div>
                <div class="w-24 text-right">
                    <p class="text-primary font-bold">$@product.Price.ToString("N0")</p>
                </div>
                <div class="w-28 text-right">
                    <p class="text-slate-300 text-sm">@product.Quantity</p>
                </div>
                <div class="w-16 flex justify-end gap-xs opacity-0 group-hover:opacity-100 transition-opacity">
                    <button class="p-xs hover:text-primary transition-colors"><span class="material-symbols-outlined text-lg" data-icon="edit"></span></button>
                    <button class="p-xs hover:text-error transition-colors"><span class="material-symbols-outlined text-lg" data-icon="delete"></span></button>
                </div>
            </div>
           }
           
            </div>

        <div class="p-lg border-t border-slate-700 flex justify-between items-center bg-slate-800/10">
            <span class="text-slate-400 text-sm font-label-md">Showing 2 of @Model.Data.Count()</span>
            <div class="flex gap-sm">
                <button class="px-md py-2 bg-slate-800 border border-slate-700 rounded-lg text-white hover:text-primary transition-colors text-sm">
                    Previous
                </button>
                <button class="px-md py-2 bg-primary text-on-primary font-bold rounded-lg hover:brightness-110 transition-all text-sm">
                    Next
                </button>
            </div>
        </div>
    </section>
</main>

<button id="btnOpenModal"
        class="fixed bottom-xl right-xl w-14 h-14 bg-primary text-on-primary rounded-full shadow-lg flex items-center justify-center hover:scale-110 active:scale-95 transition-transform z-[100] group">
    <span class="material-symbols-outlined text-3xl group-hover:rotate-90 transition-transform" data-icon="add"></span>
    <div class="absolute right-16 bg-slate-800 px-md py-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-slate-700 text-sm text-white">
        Add New Product
    </div>
</button>

<div id="productModal" class="fixed inset-0 z-[150] hidden flex items-center justify-center bg-slate-950/60 backdrop-blur-sm p-4 transition-all duration-300">
    
    <div class="bg-slate-900 border border-slate-800 w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-300" id="modalContainer">
        
        <div class="p-lg border-b border-slate-800 flex justify-between items-center bg-slate-800/20">
            <div>
                <h3 class="text-xl font-bold text-white tracking-tight">Add New Product</h3>
                <p class="text-xs text-slate-400">Enter the details to register a new item in StockStream</p>
            </div>
            <button id="btnCloseModal" class="p-2 text-slate-400 hover:text-white rounded-lg hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form asp-action="CreateProduct" asp-controller="Firmeza" method="post" class="p-lg space-y-md text-sm text-slate-300">
            
            <div class="flex flex-col gap-xs">
                <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">Product Name</label>
                <input type="text" name="Name" required placeholder="e.g., Vanguard Chrono X" 
                       class="bg-slate-800/50 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-white w-full" />
            </div>

            <div class="grid grid-cols-2 gap-md">
                <div class="flex flex-col gap-xs">
                    <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">SKU</label>
                    <input type="text" name="Sku" placeholder="SS-XX-000" 
                           class="bg-slate-800/50 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-white w-full" />
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">Category</label>
                    <select name="Category" class="bg-slate-800 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 text-slate-300 w-full cursor-pointer">
                        <option value="Electronics">Electronics</option>
                        <option value="Hardware">Hardware</option>
                        <option value="Software">Software</option>
                        <option value="Logistics">Logistics</option>
                        <option value="Home">Home</option>
                        <option value="Clothing">Clothing</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-md">
                <div class="flex flex-col gap-xs">
                    <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">Price ($)</label>
                    <input type="number" step="0.01" name="Price" required placeholder="0.00" 
                           class="bg-slate-800/50 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-white w-full" />
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">Initial Stock</label>
                    <input type="number" name="Quantity" required placeholder="0" 
                           class="bg-slate-800/50 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-white w-full" />
                </div>
            </div>

            <div class="flex flex-col gap-xs">
                <label class="font-semibold text-xs text-slate-400 uppercase tracking-wider">Image URL</label>
                <input type="url" name="ImageUrl" placeholder="https://example.com/image.jpg" 
                       class="bg-slate-800/50 border border-slate-700 rounded-xl px-md py-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary text-white w-full" />
            </div>

            <div class="flex justify-end gap-sm border-t border-slate-800 pt-md mt-lg">
                <button type="button" id="btnCancelModal" class="px-lg py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white font-medium rounded-xl transition-colors">
                    Cancel
                </button>
                <button type="submit" class="px-lg py-2 bg-primary text-on-primary font-bold rounded-xl hover:brightness-110 shadow-lg shadow-primary/20 transition-all">
                    Save Product
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const modal = document.getElementById("productModal");
        const container = document.getElementById("modalContainer");
        const btnOpen = document.getElementById("btnOpenModal");
        const btnClose = document.getElementById("btnCloseModal");
        const btnCancel = document.getElementById("btnCancelModal");

        function openModal() {
            modal.classList.remove("hidden");
           
            setTimeout(() => {
                modal.classList.add("opacity-100");
                container.classList.remove("scale-95", "opacity-0");
                container.classList.add("scale-100", "opacity-100");
            }, 10);
        }

        function closeModal() {
            container.classList.remove("scale-100", "opacity-100");
            container.classList.add("scale-95", "opacity-0");
            setTimeout(() => {
                modal.classList.add("hidden");
            }, 300); 
        }

        // Eventos
        btnOpen.addEventListener("click", openModal);
        btnClose.addEventListener("click", closeModal);
        btnCancel.addEventListener("click", closeModal);

        
        modal.addEventListener("click", function (e) {
            if (e.target === modal) {
                closeModal();
            }
        });
    });
</script>