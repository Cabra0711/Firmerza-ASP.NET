@inject IHttpContextAccessor HttpContextAccessor

@{
ViewData["Title"] = "Dashboard Admin";

var nombreAdmin = HttpContextAccessor.HttpContext?.Session.GetString("Username") ?? "Admin";
}

<aside
    class="h-screen w-64 fixed left-0 top-0 border-r border-outline-variant/20 bg-surface-container/60 backdrop-blur-xl dark:bg-surface-container/60 shadow-xl flex flex-col py-lg z-50">
    <div class="px-md mb-xl">
        <h1 class="font-headline-md text-headline-md font-bold text-primary dark:text-primary-fixed-dim">
            StockStream</h1>
        <p class="font-label-md text-label-md text-on-surface-variant opacity-70">Admin Terminal</p>
    </div>
    <nav class="flex-1 space-y-xs">
        <!-- Dashboard -->
        <a class="flex items-center gap-md text-on-surface-variant hover:text-on-surface px-md py-sm hover:bg-surface-bright/50 transition-all duration-200 active:scale-95"
           asp-action="Admin" asp-controller="Firmeza">
            <span class="material-symbols-outlined">dashboard</span>
            <span class="font-body-md text-body-md">Products</span>
        </a>
        <!-- Inventory -->
        <a class="flex items-center gap-md text-on-surface-variant hover:text-on-surface px-md py-sm hover:bg-surface-bright/50 transition-all duration-200 active:scale-95"
           asp-action="Customer" asp-controller="Firmeza">
            <span class="material-symbols-outlined">inventory_2</span>
            <span class="font-body-md text-body-md">Customers</span>
        </a>
        <!-- Analytics -->
        <a class="flex items-center gap-md text-on-surface-variant hover:text-on-surface px-md py-sm hover:bg-surface-bright/50 transition-all duration-200 active:scale-95"
           asp-action="Sells" asp-controller="Firmeza">
            <span class="material-symbols-outlined">analytics</span>
            <span class="font-body-md text-body-md">Sells</span>
        </a>
        <!-- Settings -->
        <a class="flex items-center gap-md text-on-surface-variant hover:text-on-surface px-md py-sm hover:bg-surface-bright/50 transition-all duration-200 active:scale-95"
           href="#">
            <span class="material-symbols-outlined">settings</span>
            <span class="font-body-md text-body-md">Settings</span>
        </a>
    </nav>
    <div class="px-md mt-auto">
        <button
            class="w-full flex items-center justify-center gap-sm bg-primary text-on-primary py-sm rounded-lg font-label-md text-label-md hover:shadow-[0_0_20px_rgba(192,193,255,0.4)] transition-all">
            <span class="material-symbols-outlined text-[20px]">add</span>
            New Entry
        </button>
    </div>

    <div class="mt-auto px-md pb-md flex items-center gap-md border-t border-outline-variant/20 pt-md">
        <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center relative">
            <span class="material-symbols-outlined text-on-primary-container text-2xl" style="font-variation-settings: 'FILL' 1;">account_circle</span>
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 absolute bottom-0 right-0 border-2 border-slate-900 animate-pulse"></div>
        </div>
        <div class="flex flex-col overflow-hidden">
            <span class="font-label-md text-label-md text-on-surface font-bold truncate">@nombreAdmin</span>
            <span class="text-[10px] text-on-surface-variant uppercase tracking-wider font-semibold">Rol: Administrador</span>
        </div>
    </div>
</aside>

<!-- Main Content Canvas -->
<main class="ml-64 flex-1 flex flex-col min-h-screen">
    <!-- TopNavBar -->
    <header
        class="fixed top-0 right-0 w-[calc(100%-16rem)] h-16 bg-surface-dim/40 backdrop-blur-md dark:bg-surface-dim/40 border-b border-outline-variant/10 shadow-sm flex justify-between items-center px-xl z-40">
        <div
            class="flex items-center flex-1 max-w-md focus-within:ring-2 focus-within:ring-primary/50 rounded-lg transition-colors bg-surface-container-low px-sm py-xs">
            <span class="material-symbols-outlined text-on-surface-variant mr-sm">search</span>
            <input class="bg-transparent border-none focus:ring-0 text-on-surface font-label-md text-label-md w-full"
                   placeholder="Search orders, transactions..." type="text"/>
        </div>
        <div class="flex items-center gap-lg">
            <div class="flex gap-md">
                <button
                    class="material-symbols-outlined p-xs hover:bg-surface-variant/30 rounded-lg transition-colors text-on-surface-variant">
                    notifications
                </button>
                <button
                    class="material-symbols-outlined p-xs hover:bg-surface-variant/30 rounded-lg transition-colors text-on-surface-variant">
                    help_outline
                </button>
            </div>
        </div>
    </header>

    <!-- Content Area -->
    <div class="pt-24 px-xl pb-xl flex-1 kinetic-gradient">
        <!-- Header Section -->
        <div class="flex justify-between items-end mb-xl">
            <div>
                <h2 class="font-headline-lg text-headline-lg text-on-surface">Sales History</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Review and manage recent commercial
                    performance across all channels.</p>
            </div>
            <div class="flex gap-md">
                <button
                    class="px-md py-sm glass-card rounded-lg flex items-center gap-sm font-label-md text-label-md text-secondary border-secondary/20 hover:bg-secondary/10 transition-colors">
                    <span class="material-symbols-outlined">file_download</span> Export CSV
                </button>
                <button
                    class="px-md py-sm bg-primary text-on-primary rounded-lg flex items-center gap-sm font-label-md text-label-md hover:shadow-lg transition-all">
                    <span class="material-symbols-outlined">filter_list</span> Filter Results
                </button>
            </div>
        </div>

        <!-- Bento Grid - High Level Metrics -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-lg mb-xl">
            <!-- Total Sales Widget -->
            <div class="md:col-span-4 glass-card p-xl rounded-xl relative overflow-hidden group">
                <div
                    class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
                <div class="flex justify-between items-start mb-md">
                    <div>
                        <p class="font-label-md text-label-md text-on-surface-variant">Total Sales</p>
                        <h3 class="font-display-lg text-display-lg text-primary mt-xs">$142,850</h3>
                    </div>
                    <div
                        class="bg-tertiary/10 text-tertiary px-sm py-xs rounded-full flex items-center gap-xs font-label-md text-[12px]">
                        <span class="material-symbols-outlined text-[14px]">trending_up</span>
                        +12.4%
                    </div>
                </div>
                <div class="h-16 w-full mt-lg">
                    <svg class="w-full h-full" viewBox="0 0 200 40">
                        <path class="sparkline" d="M0 35 Q 20 20, 40 30 T 80 15 T 120 25 T 160 5 T 200 10" fill="none"
                              stroke="#c0c1ff" stroke-width="2"></path>
                    </svg>
                </div>
            </div>
            <!-- Monthly Revenue Widget -->
            <div class="md:col-span-4 glass-card p-xl rounded-xl relative overflow-hidden group">
                <div
                    class="absolute top-0 right-0 w-32 h-32 bg-secondary/5 rounded-full -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-500"></div>
                <div class="flex justify-between items-start mb-md">
                    <div>
                        <p class="font-label-md text-label-md text-on-surface-variant">Monthly Revenue</p>
                        <h3 class="font-display-lg text-display-lg text-secondary mt-xs">$34,210</h3>
                    </div>
                    <div
                        class="bg-tertiary/10 text-tertiary px-sm py-xs rounded-full flex items-center gap-xs font-label-md text-[12px]">
                        <span class="material-symbols-outlined text-[14px]">trending_up</span>
                        +8.2%
                    </div>
                </div>
                <div class="h-16 w-full mt-lg">
                    <svg class="w-full h-full" viewBox="0 0 200 40">
                        <path class="sparkline" d="M0 30 Q 30 35, 60 20 T 100 25 T 140 10 T 180 15 T 200 5" fill="none"
                              stroke="#ffb0cd" stroke-width="2"></path>
                    </svg>
                </div>
            </div>
            <!-- Insights Widget -->
            <div
                class="md:col-span-4 glass-card p-xl rounded-xl flex items-center justify-center border-dashed border-outline/20">
                <div class="text-center">
                    <div
                        class="w-16 h-16 bg-surface-container-highest rounded-full flex items-center justify-center mx-auto mb-md">
                        <span class="material-symbols-outlined text-primary text-[32px]">insights</span>
                    </div>
                    <p class="font-label-md text-label-md text-on-surface-variant">View Full Sales Report</p>
                    <button
                        class="mt-sm font-label-md text-label-md text-primary underline underline-offset-4 hover:text-primary-container transition-colors">
                        Analyze Data
                    </button>
                </div>
            </div>
        </div>

        <!-- Transactions Table Section -->
        <div class="glass-card rounded-xl overflow-hidden mb-xl">
            <div
                class="px-xl py-lg border-b border-outline-variant/10 flex justify-between items-center bg-surface-container-low/40">
                <h4 class="font-headline-md text-headline-md text-on-surface">Recent Transactions</h4>
                <div class="flex gap-md">
                    <select
                        class="bg-surface-container-highest/50 border-none rounded-lg text-on-surface font-label-md text-label-md focus:ring-primary/50 py-sm">
                        <option>All Status</option>
                        <option>Completed</option>
                        <option>Pending</option>
                        <option>Cancelled</option>
                    </select>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                    <tr class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest bg-surface-container-highest/20">
                        <th class="px-xl py-md font-semibold">Transaction ID</th>
                        <th class="px-xl py-md font-semibold">Customer Name</th>
                        <th class="px-xl py-md font-semibold">Amount</th>
                        <th class="px-xl py-md font-semibold">Status</th>
                        <th class="px-xl py-md font-semibold">Date</th>
                        <th class="px-xl py-md font-semibold text-right">Actions</th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/5">
                    <!-- Row 1 -->
