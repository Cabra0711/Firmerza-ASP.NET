                        </td>
                    </tr>
                    <!-- Row 2 -->
                    <tr class="hover:bg-surface-bright/20 transition-colors group">
                        <td class="px-xl py-lg">
                            <span class="font-code text-code text-primary">#TXN-88422</span>
                        </td>
                        <td class="px-xl py-lg flex items-center gap-sm">
                            <img alt="Customer" class="w-8 h-8 rounded-full"
                                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuBq1RIHhzZucZnWnPJETRzUJOUyCabWpsoRot_BkFSf4GA49Fe3PiH87Qi1U_TVg1HIDyvSaqexth4SeHoCvELnpfegpVZZYY6dJW3_Fp7l15SHx3Q-63cxYGaKm2KD0uKBzP38BssbcU7CKcONpAJC1vXKUqS7jfDibkmt8SsEzW284E3FKdkd3ivRz6GXNdfq0XYeN9Y8H1q3DR9Z_k50BpBY1gTzywqYLi1ZfPThE37R8c8KrP-JP_zua6QxLIq5guNPq2miwRg"/>
                            <span class="font-body-md text-body-md text-on-surface">Elena Rodriguez</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span class="font-body-md text-body-md font-bold text-on-surface">$3,150.50</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span
                                class="px-md py-xs rounded-full bg-primary/10 text-primary font-label-md text-[12px] border border-primary/20">Pending</span>
                        </td>
                        <td class="px-xl py-lg text-on-surface-variant font-label-md text-label-md">Oct 24, 2023</td>
                        <td class="px-xl py-lg text-right">
                            <button
                                class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">
                                more_vert
                            </button>
                        </td>
                    </tr>
                    <!-- Row 3 -->
                    <tr class="hover:bg-surface-bright/20 transition-colors group">
                        <td class="px-xl py-lg">
                            <span class="font-code text-code text-primary">#TXN-88423</span>
                        </td>
                        <td class="px-xl py-lg flex items-center gap-sm">
                            <img alt="Customer" class="w-8 h-8 rounded-full"
                                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuCyw55rOoOLRZZsQZ9vgLdVBAzxhpHWynbKTZ5E3_fDKMokv5QosAJ5LInE-vwK0u8wX_LAaMi_cuOOEeBtfJBIUplCr00gC7FaOrr4QJxFnm28lPuhO1adKcwaGf7szfV-5gA8b3mfxnEY9YfGhopsniz3OHDXS0EU53IfmablPRS5hkUE4zE-eJxbWzCaIHSyA9xZlwzAzyzfTW4KhbF1UPcYuCK71X-2NNAb5lZRQNhJcw7n4UcOzcwfvV4XZobRBN0BxxiKnMw"/>
                            <span class="font-body-md text-body-md text-on-surface">Marcus Thorne</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span class="font-body-md text-body-md font-bold text-on-surface">$890.00</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span
                                class="px-md py-xs rounded-full bg-error/10 text-error font-label-md text-[12px] border border-error/20">Cancelled</span>
                        </td>
                        <td class="px-xl py-lg text-on-surface-variant font-label-md text-label-md">Oct 23, 2023</td>
                        <td class="px-xl py-lg text-right">
                            <button
                                class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">
                                more_vert
                            </button>
                        </td>
                    </tr>
                    <!-- Row 4 -->
                    <tr class="hover:bg-surface-bright/20 transition-colors group">
                        <td class="px-xl py-lg">
                            <span class="font-code text-code text-primary">#TXN-88424</span>
                        </td>
                        <td class="px-xl py-lg flex items-center gap-sm">
                            <img alt="Customer" class="w-8 h-8 rounded-full"
                                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuBAKhbcw4JQr5pcTAh8EWDLLv3d86vB1gaTzlRsiWWT8P3yl1oICO3G8e-BD2aHGz5BwQepLmZq2BxjYUNAIN7l9LECUwf6FVqL5XnbRl8YppC9G6ffdPsfKGZXzmQgw4Mkzqooomf6E30jXujvh80vG0edlBYCrNIWvHk7Ik_FgeqXgbWxJzKJiltDkwL3uK1t94jja3Os9MDt8qRmHLPLpVAXg3l7OkmKrYHEKxuCl9H6SWgDYbG3Qzv3wja-8-5PFEc3HcM3xUU"/>
