                </table>
            </div>
            <div
                class="px-xl py-md bg-surface-container/20 flex justify-between items-center border-t border-outline-variant/10">
                <p class="font-label-md text-label-md text-on-surface-variant">Showing 4 of 1,280 transactions</p>
                <div class="flex gap-sm">
                    <button
                        class="p-xs glass-card rounded-lg hover:bg-surface-variant transition-colors disabled:opacity-30"
                        disabled="">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </button>
                    <button class="p-xs glass-card rounded-lg hover:bg-surface-variant transition-colors">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Bottom Action Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
            <div
                class="md:col-span-2 glass-card p-xl rounded-xl flex items-center gap-xl bg-gradient-to-br from-primary/10 to-transparent">
                <div class="flex-1">
                    <h5 class="font-headline-md text-headline-md text-on-surface">New Customer Growth</h5>
                    <p class="font-body-md text-body-md text-on-surface-variant mt-sm">Your store has seen a 15%
                        increase in first-time buyers this week. Optimize your retention strategy to maximize lifetime
                        value.</p>
                    <button
                        class="mt-md font-label-md text-label-md text-primary font-bold hover:tracking-wide transition-all uppercase">
                        View CRM Insights
                    </button>
                </div>
                <div class="hidden lg:block w-32 h-32 relative">
                    <div
                        class="absolute inset-0 border-2 border-primary/20 rounded-full animate-spin [animation-duration:10s]"></div>
                    <div
                        class="absolute inset-4 border-2 border-secondary/20 rounded-full animate-reverse-spin [animation-duration:8s]"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
