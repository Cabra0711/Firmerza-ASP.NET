                            <span class="font-body-md text-body-md text-on-surface">Felix Vossen</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span class="font-body-md text-body-md font-bold text-on-surface">$1,240.00</span>
                        </td>
                        <td class="px-xl py-lg">
                            <span
                                class="px-md py-xs rounded-full bg-tertiary/10 text-tertiary font-label-md text-[12px] border border-tertiary/20">Completed</span>
                        </td>
                        <td class="px-xl py-lg text-on-surface-variant font-label-md text-label-md">Oct 24, 2023</td>
